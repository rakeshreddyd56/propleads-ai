# === REQUIRED ===

# Database (Neon — https://neon.tech)
DATABASE_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/propleads?sslmode=require"

# Auth (Clerk — https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AI (Anthropic — https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# File Storage (Vercel Blob — auto-provisioned on Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Background Jobs (Inngest — https://inngest.com)
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=signkey-prod-xxx

# === OPTIONAL ===

# Scraping — Reddit (https://reddit.com/prefs/apps)
REDDIT_CLIENT_ID=xxx
REDDIT_CLIENT_SECRET=xxx
REDDIT_USER_AGENT="PropLeadsAI/1.0 (by /u/your_username)"

# Scraping — Web (https://firecrawl.dev)
