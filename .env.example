# === REQUIRED ===

# Database (Neon — https://neon.tech)
DATABASE_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/propleads?sslmode=require"

# Auth (Clerk — https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AI (Anthropic — https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# File Storage (Vercel Blob — auto-provisioned on Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# === SCRAPING (choose what you need) ===

# Reddit — FREE, no keys needed (uses public .json endpoints)
# Reddit scraping works out of the box!

# Apify — for 99acres, MagicBricks, NoBroker, Facebook, Instagram,
#          Twitter, YouTube, LinkedIn, Quora, Telegram, Google Maps
# Sign up at https://apify.com — free tier: $5/month credit
APIFY_API_TOKEN=apify_api_xxx

# Firecrawl — for CommonFloor forum scraping (optional)
FIRECRAWL_API_KEY=fc-xxx

# === OPTIONAL ===

# Outreach — Email (https://resend.com)
RESEND_API_KEY=re_xxx

# Outreach — WhatsApp (https://aisensy.com)
AISENSY_API_KEY=xxx

# Enrichment (https://apollo.io)
APOLLO_API_KEY=xxx

# Enrichment (https://hunter.io)
HUNTER_API_KEY=xxx
